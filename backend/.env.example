# .env.example
# Copy this file to .env and update values for your environment

# Flask Configuration
FLASK_ENV=development
DEBUG=True

# Database Configuration (SQLite - file-based, no server needed)
# SQLite stores data in schoolms.db in the same directory
DATABASE_URL=sqlite:///schoolms.db

# JWT Configuration
# Change this to a strong secret in production
JWT_SECRET_KEY=your-secret-key-change-in-production

# API Configuration
API_PORT=5000

# Logging
LOG_LEVEL=INFO
